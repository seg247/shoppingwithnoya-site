---
export interface Props {
  deal: {
    slug: string;
    asin: string;
    title: string;
    url: string;
    price: string | null;
    discount: number;
    rating: string;
    category: string;
    ts: string;
    imageUrl?: string | null;
  };
  base: string;
}

const { deal, base } = Astro.props;

function ratingColor(r: string) {
  if (r === 'FIRE') return '#ef4444';
  if (r === 'HOT')  return '#f97316';
  if (r === 'WARM') return '#eab308';
  if (r === 'GOOD') return '#22c55e';
  return '#3b82f6';
}

const color = ratingColor(deal.rating);
// Use real CDN imageUrl from scraper; fall back to ASIN thumbnail
const imgSrc = deal.imageUrl ||
  (deal.asin ? `https://images-na.ssl-images-amazon.com/images/P/${deal.asin}.01._SCLZZZZZZZ_.jpg` : null);
const timeAgo = new Date(deal.ts).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'America/New_York' });
---

<a href={`${base}/deals/${deal.slug}`} class="deal-card">
  <div class="card-img">
    {imgSrc
      ? <img src={imgSrc} alt={deal.title} loading="lazy" width="120" height="120" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
      : null}
    <div class="img-fallback" style={imgSrc ? 'display:none' : ''}>📦</div>
  </div>
  <div class="card-body">
    <div class="card-title">{deal.title}</div>
    <div class="card-badges">
      {deal.discount > 0 && (
        <span class="badge-discount" style={`background:${color}`}>💸 {deal.discount}% OFF</span>
      )}
      {deal.price && (
        <span class="badge-price">💵 {deal.price}</span>
      )}
      <span class="badge-rating" style={`color:${color};border-color:${color}`}>{deal.rating}</span>
    </div>
    <div class="card-date">{timeAgo}</div>
  </div>
</a>

<style>
  .deal-card {
    background: #1e293b;
    border-radius: 12px;
    padding: 14px;
    display: flex;
    gap: 14px;
    color: #e2e8f0;
    text-decoration: none;
    transition: background 0.15s, transform 0.1s;
    height: 100%;
  }
  .deal-card:hover { background: #243347; transform: translateY(-2px); text-decoration: none; }
  .card-img {
    width: 90px; height: 90px; flex-shrink: 0;
    border-radius: 8px; overflow: hidden; background: #334155;
    display: flex; align-items: center; justify-content: center;
  }
  .card-img img { width: 100%; height: 100%; object-fit: cover; }
  .img-fallback { font-size: 2rem; display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; }
  .card-body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 8px; }
  .card-title { font-size: 0.88rem; font-weight: 600; line-height: 1.3; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .card-badges { display: flex; flex-wrap: wrap; gap: 5px; }
  .badge-discount { font-size: 0.7rem; padding: 3px 8px; border-radius: 20px; color: #fff; white-space: nowrap; }
  .badge-price { font-size: 0.7rem; padding: 3px 8px; border-radius: 20px; background: #14532d; color: #86efac; white-space: nowrap; }
  .badge-rating { font-size: 0.7rem; padding: 3px 8px; border-radius: 20px; border: 1px solid; background: transparent; white-space: nowrap; }
  .card-date { font-size: 0.72rem; color: #64748b; margin-top: auto; }
</style>
