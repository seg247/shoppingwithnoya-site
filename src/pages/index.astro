---
import Base from '../layouts/Base.astro';
import DealCard from '../components/DealCard.astro';
import siteData from '../data/site-data.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Filter out placeholder titles on the frontend too (belt + suspenders)
const isPlaceholder = (t: string) =>
  !t || /^\$[\d.,x]+ was \$[\d.,x]+$/i.test(t) || /^as low as/i.test(t) || t.length < 10;

const deals = siteData.posts.filter(p => !isPlaceholder(p.title)).slice(0, 60);
const latest = deals.find(d => d.asin);
---

<Base
  title="Shopping With Noya — Daily Amazon Deals"
  description="The best Amazon deals updated every day. Save big on home, beauty, kitchen, and more. Follow our Telegram channel for instant deal alerts."
  image={latest?.asin ? `https://images-na.ssl-images-amazon.com/images/P/${latest.asin}.01._SCLZZZZZZZ_.jpg` : undefined}
>

  <!-- Hero -->
  <section class="hero">
    <h1>🛍️ Daily Amazon Deals</h1>
    <p class="hero-sub">Hand-picked deals updated every few minutes. Never overpay on Amazon again.</p>
    <a href="https://t.me/shoppingwithnoya" class="hero-cta" target="_blank" rel="noopener">
      🔔 Get instant alerts on Telegram →
    </a>
  </section>

  <!-- Stats bar -->
  <div class="stats-bar">
    <div class="stat"><strong>{siteData.total}</strong> deals posted</div>
    <div class="stat"><strong>Free</strong> Amazon deals daily</div>
    <div class="stat">Updated <strong>every 2 min</strong></div>
  </div>

  <!-- Deals grid -->
  <section>
    <h2 class="section-title">Latest Deals</h2>
    <div class="deals-grid">
      {deals.map(deal => (
        <DealCard deal={deal} base={base} />
      ))}
    </div>
  </section>

  <!-- Telegram CTA -->
  <section class="tg-cta">
    <div class="tg-box">
      <div class="tg-icon">📲</div>
      <div>
        <h2>Never miss a deal</h2>
        <p>Join our free Telegram channel and get the best Amazon deals delivered instantly — before they sell out.</p>
        <a href="https://t.me/shoppingwithnoya" class="tg-btn" target="_blank" rel="noopener">
          Join @shoppingwithnoya — It's Free
        </a>
      </div>
    </div>
  </section>

</Base>

<style>
  /* Hero */
  .hero {
    text-align: center;
    padding: 52px 20px 36px;
  }
  .hero h1 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 800;
    margin-bottom: 14px;
    line-height: 1.2;
  }
  .hero-sub {
    font-size: 1.05rem;
    color: #94a3b8;
    max-width: 480px;
    margin: 0 auto 28px;
    line-height: 1.6;
  }
  .hero-cta {
    display: inline-block;
    background: #0088cc;
    color: #fff !important;
    padding: 13px 30px;
    border-radius: 30px;
    font-size: 1rem;
    font-weight: 600;
    transition: background 0.15s;
    text-decoration: none;
  }
  .hero-cta:hover { background: #0077b5; text-decoration: none; }

  /* Stats bar */
  .stats-bar {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0;
    margin: 0 0 44px;
    background: #1e293b;
    border-radius: 12px;
    overflow: hidden;
  }
  .stat {
    flex: 1;
    min-width: 140px;
    font-size: 0.9rem;
    color: #94a3b8;
    padding: 16px 24px;
    text-align: center;
    border-right: 1px solid #334155;
  }
  .stat:last-child { border-right: none; }
  .stat strong { color: #e2e8f0; display: block; font-size: 1.1rem; margin-bottom: 2px; }

  /* Section title */
  .section-title {
    font-size: 1rem;
    font-weight: 700;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 20px;
  }

  /* Grid */
  .deals-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 14px;
    margin-bottom: 52px;
  }

  /* Telegram CTA */
  .tg-cta { margin-bottom: 20px; }
  .tg-box {
    background: #0c2340;
    border: 1px solid rgba(0,136,204,0.3);
    border-radius: 16px;
    padding: 36px 40px;
    display: flex;
    gap: 28px;
    align-items: center;
  }
  .tg-icon { font-size: 3.5rem; flex-shrink: 0; }
  .tg-box h2 { font-size: 1.4rem; font-weight: 700; margin-bottom: 10px; }
  .tg-box p { color: #94a3b8; margin-bottom: 22px; line-height: 1.6; }
  .tg-btn {
    display: inline-block;
    background: #0088cc;
    color: #fff !important;
    padding: 13px 26px;
    border-radius: 10px;
    font-weight: 700;
    font-size: 0.95rem;
    transition: background 0.15s;
    text-decoration: none;
  }
  .tg-btn:hover { background: #0077b5; text-decoration: none; }

  @media (max-width: 640px) {
    .tg-box { flex-direction: column; padding: 24px; text-align: center; }
    .stats-bar { border-radius: 12px; }
    .stat { border-right: none; border-bottom: 1px solid #334155; }
    .stat:last-child { border-bottom: none; }
  }
</style>
