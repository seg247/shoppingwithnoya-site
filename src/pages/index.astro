---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const dataUrl = `${base}/site-data.json`;
---

<Base
  title="Shopping With Noya — Daily Amazon Deals"
  description="The best Amazon deals updated every day. Save big on home, beauty, kitchen, and more. Follow our Telegram channel for instant deal alerts."
>

  <!-- Hero -->
  <section class="hero">
    <h1>🛍️ Daily Amazon Deals</h1>
    <p class="hero-sub">Hand-picked deals updated every few minutes. Never overpay on Amazon again.</p>
    <a href="https://t.me/shoppingwithnoya" class="hero-cta" target="_blank" rel="noopener">
      🔔 Get instant alerts on Telegram →
    </a>
  </section>

  <!-- Stats bar -->
  <div class="stats-bar" id="stats-bar">
    <div class="stat"><strong id="stat-total">—</strong> deals posted</div>
    <div class="stat"><strong>Free</strong> Amazon deals daily</div>
    <div class="stat">Updated <strong>every 2 min</strong></div>
  </div>

  <!-- Deals grid -->
  <section>
    <h2 class="section-title">Latest Deals</h2>
    <div id="deals-grid" class="deals-grid">
      <div class="loading">Loading deals...</div>
    </div>
  </section>

  <!-- Telegram CTA -->
  <section class="tg-cta">
    <div class="tg-box">
      <div class="tg-icon">📲</div>
      <div>
        <h2>Never miss a deal</h2>
        <p>Join our free Telegram channel and get the best Amazon deals delivered instantly — before they sell out.</p>
        <a href="https://t.me/shoppingwithnoya" class="tg-btn" target="_blank" rel="noopener">
          Join @shoppingwithnoya — It's Free
        </a>
      </div>
    </div>
  </section>

</Base>

<script define:vars={{ base, dataUrl }}>
  const PLACEHOLDER_RE = /^\$[\d.,x]+ was \$[\d.,x]+$/i;

  function isPlaceholder(t) {
    return !t || PLACEHOLDER_RE.test(t) || /^as low as/i.test(t) || t.length < 10;
  }

  function ratingColor(r) {
    if (r === 'FIRE') return '#ef4444';
    if (r === 'HOT')  return '#f97316';
    if (r === 'WARM') return '#eab308';
    if (r === 'GOOD') return '#22c55e';
    return '#3b82f6';
  }

  function timeAgo(ts) {
    return new Date(ts).toLocaleDateString('en-US', {
      month: 'short', day: 'numeric', year: 'numeric', timeZone: 'America/New_York'
    });
  }

  function renderCard(deal) {
    const color = ratingColor(deal.rating);
    // Use real CDN imageUrl from scraper; fall back to ASIN thumbnail
    const imgSrc = deal.imageUrl ||
      (deal.asin ? `https://images-na.ssl-images-amazon.com/images/P/${deal.asin}.01._SCLZZZZZZZ_.jpg` : null);
    const discountBadge = deal.discount > 0
      ? `<span class="badge-discount" style="background:${color}">💸 ${deal.discount}% OFF</span>` : '';
    const priceBadge = deal.price
      ? `<span class="badge-price">💵 ${deal.price}</span>` : '';
    const img = imgSrc
      ? `<img src="${imgSrc}" alt="" loading="lazy" width="120" height="120" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">`
      : '';

    return `
      <a href="${base}/deals/${deal.slug}" class="deal-card">
        <div class="card-img">
          ${img}
          <div class="img-fallback" ${imgSrc ? 'style="display:none"' : ''}>📦</div>
        </div>
        <div class="card-body">
          <div class="card-title">${deal.title}</div>
          <div class="card-badges">
            ${discountBadge}
            ${priceBadge}
            <span class="badge-rating" style="color:${color};border-color:${color}">${deal.rating}</span>
          </div>
          <div class="card-date">${timeAgo(deal.ts)}</div>
        </div>
      </a>`;
  }

  async function loadDeals() {
    const grid = document.getElementById('deals-grid');
    try {
      const res = await fetch(`${dataUrl}?t=${Date.now()}`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();

      // Update stats
      const statTotal = document.getElementById('stat-total');
      if (statTotal) statTotal.textContent = data.total || data.posts?.length || '—';

      const deals = (data.posts || [])
        .filter(p => !isPlaceholder(p.title))
        .slice(0, 60);

      if (deals.length === 0) {
        grid.innerHTML = '<div class="loading">No deals found.</div>';
        return;
      }

      grid.innerHTML = deals.map(renderCard).join('');
    } catch (err) {
      grid.innerHTML = '<div class="loading">Could not load deals. Try refreshing.</div>';
      console.error('Failed to load site-data.json:', err);
    }
  }

  loadDeals();
</script>

<style>
  /* Hero */
  .hero {
    text-align: center;
    padding: 52px 20px 36px;
  }
  .hero h1 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 800;
    margin-bottom: 14px;
    line-height: 1.2;
  }
  .hero-sub {
    font-size: 1.05rem;
    color: #94a3b8;
    max-width: 480px;
    margin: 0 auto 28px;
    line-height: 1.6;
  }
  .hero-cta {
    display: inline-block;
    background: #0088cc;
    color: #fff !important;
    padding: 13px 30px;
    border-radius: 30px;
    font-size: 1rem;
    font-weight: 600;
    transition: background 0.15s;
    text-decoration: none;
  }
  .hero-cta:hover { background: #0077b5; text-decoration: none; }

  /* Stats bar */
  .stats-bar {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0;
    margin: 0 0 44px;
    background: #1e293b;
    border-radius: 12px;
    overflow: hidden;
  }
  .stat {
    flex: 1;
    min-width: 140px;
    font-size: 0.9rem;
    color: #94a3b8;
    padding: 16px 24px;
    text-align: center;
    border-right: 1px solid #334155;
  }
  .stat:last-child { border-right: none; }
  .stat strong { color: #e2e8f0; display: block; font-size: 1.1rem; margin-bottom: 2px; }

  /* Section title */
  .section-title {
    font-size: 1rem;
    font-weight: 700;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 20px;
  }

  /* Grid */
  .deals-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 14px;
    margin-bottom: 52px;
  }

  /* Loading */
  .loading {
    color: #64748b;
    padding: 40px;
    text-align: center;
    grid-column: 1/-1;
  }

  /* Deal card (inlined for client-render) */
  :global(.deal-card) {
    background: #1e293b; border-radius: 12px; padding: 14px;
    display: flex; gap: 14px; color: #e2e8f0; text-decoration: none;
    transition: background 0.15s, transform 0.1s; height: 100%;
  }
  :global(.deal-card:hover) { background: #243347; transform: translateY(-2px); text-decoration: none; }
  :global(.card-img) {
    width: 90px; height: 90px; flex-shrink: 0;
    border-radius: 8px; overflow: hidden; background: #334155;
    display: flex; align-items: center; justify-content: center;
  }
  :global(.card-img img) { width: 100%; height: 100%; object-fit: cover; }
  :global(.img-fallback) { font-size: 2rem; display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; }
  :global(.card-body) { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 8px; }
  :global(.card-title) { font-size: 0.88rem; font-weight: 600; line-height: 1.3; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  :global(.card-badges) { display: flex; flex-wrap: wrap; gap: 5px; }
  :global(.badge-discount) { font-size: 0.7rem; padding: 3px 8px; border-radius: 20px; color: #fff; white-space: nowrap; }
  :global(.badge-price) { font-size: 0.7rem; padding: 3px 8px; border-radius: 20px; background: #14532d; color: #86efac; white-space: nowrap; }
  :global(.badge-rating) { font-size: 0.7rem; padding: 3px 8px; border-radius: 20px; border: 1px solid; background: transparent; white-space: nowrap; }
  :global(.card-date) { font-size: 0.72rem; color: #64748b; margin-top: auto; }

  /* Telegram CTA */
  .tg-cta { margin-bottom: 20px; }
  .tg-box {
    background: #0c2340;
    border: 1px solid rgba(0,136,204,0.3);
    border-radius: 16px;
    padding: 36px 40px;
    display: flex;
    gap: 28px;
    align-items: center;
  }
  .tg-icon { font-size: 3.5rem; flex-shrink: 0; }
  .tg-box h2 { font-size: 1.4rem; font-weight: 700; margin-bottom: 10px; }
  .tg-box p { color: #94a3b8; margin-bottom: 22px; line-height: 1.6; }
  .tg-btn {
    display: inline-block;
    background: #0088cc;
    color: #fff !important;
    padding: 13px 26px;
    border-radius: 10px;
    font-weight: 700;
    font-size: 0.95rem;
    transition: background 0.15s;
    text-decoration: none;
  }
  .tg-btn:hover { background: #0077b5; text-decoration: none; }

  @media (max-width: 640px) {
    .tg-box { flex-direction: column; padding: 24px; text-align: center; }
    .stats-bar { border-radius: 12px; }
    .stat { border-right: none; border-bottom: 1px solid #334155; }
    .stat:last-child { border-bottom: none; }
  }
</style>
