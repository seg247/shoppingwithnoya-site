---
import Base from '../../layouts/Base.astro';
import siteData from '../../data/site-data.json';

export async function getStaticPaths() {
  return siteData.posts.map(deal => ({
    params: { slug: deal.slug },
    props: { deal },
  }));
}

const { deal } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const imgUrl = deal.asin
  ? `https://images-na.ssl-images-amazon.com/images/P/${deal.asin}.01._SCLZZZZZZZ_.jpg`
  : null;

const pageTitle = `${deal.title} — ${deal.discount > 0 ? deal.discount + '% Off ' : ''}Deal | Shopping With Noya`;
const pageDesc = deal.discount > 0
  ? `Get ${deal.discount}% off ${deal.title}. ${deal.price ? `Now only ${deal.price}.` : ''} Grab this Amazon deal before it's gone. Follow @shoppingwithnoya for more daily deals.`
  : `${deal.title}${deal.price ? ` — ${deal.price}` : ''}. Find this and more daily Amazon deals at Shopping With Noya.`;

const dateFormatted = new Date(deal.ts).toLocaleDateString('en-US', {
  month: 'long', day: 'numeric', year: 'numeric', timeZone: 'America/New_York'
});

function ratingColor(r: string) {
  if (r === 'FIRE') return '#ef4444';
  if (r === 'HOT')  return '#f97316';
  if (r === 'WARM') return '#eab308';
  if (r === 'GOOD') return '#22c55e';
  return '#3b82f6';
}
const color = ratingColor(deal.rating);

// JSON-LD structured data
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: deal.title,
  ...(imgUrl && { image: imgUrl }),
  ...(deal.asin && { sku: deal.asin }),
  offers: {
    '@type': 'Offer',
    url: deal.url,
    priceCurrency: 'USD',
    ...(deal.price && { price: deal.price.replace(/[^0-9.]/g, '') }),
    availability: 'https://schema.org/InStock',
    seller: { '@type': 'Organization', name: 'Amazon' },
  },
};
---

<Base title={pageTitle} description={pageDesc} image={imgUrl || undefined} type="product">

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <article class="deal-page">

    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="breadcrumb">
      <a href={base || '/'}>Home</a> › <span>{deal.category}</span>
    </nav>

    <div class="deal-layout">

      <!-- Image -->
      <div class="deal-img-wrap">
        {imgUrl
          ? <img src={imgUrl} alt={deal.title} width="300" height="300" />
          : <div class="img-placeholder">📦</div>
        }
      </div>

      <!-- Info -->
      <div class="deal-info">
        <p class="deal-category">{deal.category}</p>
        <h1 class="deal-title">{deal.title}</h1>

        <div class="deal-badges">
          {deal.discount > 0 && (
            <span class="badge-discount" style={`background:${color}`}>💸 {deal.discount}% OFF</span>
          )}
          {deal.price && (
            <span class="badge-price">💵 {deal.price}</span>
          )}
          <span class="badge-rating" style={`color:${color};border-color:${color}`}>{deal.rating}</span>
        </div>

        {deal.asin && <p class="deal-asin">ASIN: {deal.asin}</p>}
        <p class="deal-date">Posted {dateFormatted}</p>

        <a href={deal.url} class="deal-btn" target="_blank" rel="noopener nofollow">
          🛒 See this deal on Amazon →
        </a>

        <p class="deal-disclosure">#ad — As an Amazon Associate I earn from qualifying purchases.</p>
      </div>
    </div>

    <!-- Telegram CTA -->
    <div class="tg-cta">
      <strong>🔔 Want deals like this every day?</strong>
      <a href="https://t.me/shoppingwithnoya" target="_blank" rel="noopener">
        Join our free Telegram channel @shoppingwithnoya →
      </a>
    </div>

    <a href={base || '/'} class="back-link">← Back to all deals</a>

  </article>

</Base>

<style>
  .deal-page { max-width: 900px; margin: 0 auto; }
  .breadcrumb { font-size: 0.8rem; color: #64748b; margin-bottom: 24px; }
  .breadcrumb a { color: #64748b; }
  .breadcrumb a:hover { color: #94a3b8; }

  .deal-layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 32px;
    margin-bottom: 32px;
  }
  @media (max-width: 640px) { .deal-layout { grid-template-columns: 1fr; } }

  .deal-img-wrap {
    background: #1e293b; border-radius: 16px;
    display: flex; align-items: center; justify-content: center;
    padding: 20px; min-height: 260px;
  }
  .deal-img-wrap img { width: 100%; height: auto; border-radius: 8px; object-fit: contain; max-height: 280px; }
  .img-placeholder { font-size: 5rem; }

  .deal-category { font-size: 0.8rem; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; }
  .deal-title { font-size: 1.5rem; font-weight: 700; line-height: 1.3; margin-bottom: 16px; }

  .deal-badges { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 16px; }
  .badge-discount { font-size: 0.85rem; padding: 5px 12px; border-radius: 20px; color: #fff; font-weight: 600; }
  .badge-price { font-size: 0.85rem; padding: 5px 12px; border-radius: 20px; background: #14532d; color: #86efac; font-weight: 600; }
  .badge-rating { font-size: 0.85rem; padding: 5px 12px; border-radius: 20px; border: 1px solid; background: transparent; font-weight: 600; }

  .deal-asin { font-size: 0.78rem; color: #475569; margin-bottom: 4px; font-family: monospace; }
  .deal-date { font-size: 0.8rem; color: #64748b; margin-bottom: 24px; }

  .deal-btn {
    display: inline-block; background: #f59e0b; color: #0f172a;
    padding: 14px 28px; border-radius: 10px; font-weight: 700; font-size: 1rem;
    transition: background 0.15s; margin-bottom: 16px;
  }
  .deal-btn:hover { background: #d97706; text-decoration: none; }

  .deal-disclosure { font-size: 0.72rem; color: #475569; }

  .tg-cta {
    background: #0c2340; border: 1px solid #0088cc44;
    border-radius: 12px; padding: 20px 24px;
    display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
    margin-bottom: 24px; font-size: 0.95rem;
  }
  .tg-cta a { color: #60a5fa; font-weight: 600; }

  .back-link { font-size: 0.85rem; color: #64748b; }
  .back-link:hover { color: #94a3b8; }
</style>
